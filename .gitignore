# .NET
bin/
obj/
*.user
*.suo
artifacts/
publish/
.vs/
.idea/

# Données machine — ne jamais commiter par défaut.
# Un rapport contient l'inventaire logiciel, les ports ouverts et les faiblesses
# de configuration d'une machine réelle : c'est une cartographie de ses points faibles.
reports/
captures/
*.capture.json

# Les fixtures de test SONT versionnées, par exception aux règles ci-dessus.
# Elles doivent être anonymisées — `rempart capture` le fait par défaut, et un test
# de la suite échoue si une capture brute se retrouve ici.
!tests/fixtures/
!tests/fixtures/*.capture.json

# Secrets
*.pfx
*.snk
.env

# Configuration locale Claude Code
.claude/settings.local.json
